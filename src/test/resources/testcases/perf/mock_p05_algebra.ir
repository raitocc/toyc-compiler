FuncDef: main()
entry_0:
    t0 = ASSIGN 0
    t1 = ASSIGN 1
while_cond_1:
    t2 = SLT t0, @LIMIT
    BEQZ t2 -> while_end_3
while_body_2:
    t3 = MOD t0, 7
    t4 = ADD t1, t3
    t5 = ADD t4, 0
    t1 = ASSIGN t5
    t6 = MUL t1, 1
    t1 = ASSIGN t6
    t7 = DIV t1, 1
    t1 = ASSIGN t7
    t8 = SUB t1, 0
    t1 = ASSIGN t8
    t9 = MOD t1, 251
    t1 = ASSIGN t9
    t10 = ADD t0, 1
    t0 = ASSIGN t10
    JMP -> while_cond_1
while_end_3:
    RET t1

