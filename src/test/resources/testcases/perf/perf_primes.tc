int is_prime(int n) {
    int i = 2;
    while (i * i <= n) {
        if (n % i == 0) {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

int main() {
    int count = 0;
    int i = 2;
    while (i < 200000) {
        if (is_prime(i)) {
            count = count + 1;
        }
        i = i + 1;
    }
    return count; // 2262
}
