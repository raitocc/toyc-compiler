FuncDef: main()
entry_0:
    t0 = ASSIGN 0
    t1 = ASSIGN 1
    t2 = ASSIGN 0
while_cond_1:
    t3 = SLT t0, @LIMIT
    BEQZ t3 -> while_end_3
while_body_2:
    t4 = ASSIGN t1
    t5 = ASSIGN t4
    t6 = ASSIGN t5
    t7 = ASSIGN t6
    t8 = ASSIGN t7
    t9 = ASSIGN t8
    t10 = ASSIGN t9
    t11 = ASSIGN t10
    t12 = ADD t2, t11
    t13 = MOD t12, 251
    t2 = ASSIGN t13
    t14 = ADD t1, 3
    t15 = MOD t14, 97
    t1 = ASSIGN t15
    t16 = ADD t0, 1
    t0 = ASSIGN t16
    JMP -> while_cond_1
while_end_3:
    RET t2

