int LIMIT = 10000000;

int main() {
    int i = 0;
    int acc = 1;
    while (i < LIMIT) {
        int a = acc + 2;
        int b = a * 3;
        int c = b - 4;
        int d = c / 5;
        int e = d + 6;
        int f = e * 7;
        int g = f - 8;
        int h = g / 9;
        acc = (h + i % 11) % 251;
        i = i + 1;
    }
    return acc;
}
