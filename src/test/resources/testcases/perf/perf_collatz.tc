int collatz_length(int n) {
    int len = 0;
    while (n > 1) {
        if (n % 2 == 0) {
            n = n / 2;
        } else {
            n = 3 * n + 1;
        }
        len = len + 1;
    }
    return len;
}

int main() {
    int max_len = 0;
    int i = 1;
    while (i < 100000) {
        int l = collatz_length(i);
        if (l > max_len) {
            max_len = l;
        }
        i = i + 1;
    }
    return max_len; // 261
}
