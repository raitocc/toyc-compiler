int DEPTH = 4000;
int ROUNDS = 4000;

int tail_rec(int n, int acc) {
    if (n == 0) {
        return acc;
    }
    return tail_rec(n - 1, (acc + 1) % 251);
}

int main() {
    int i = 0;
    int sum = 0;
    while (i < ROUNDS) {
        sum = (sum + tail_rec(DEPTH, i % 7)) % 251;
        i = i + 1;
    }
    return sum;
}
