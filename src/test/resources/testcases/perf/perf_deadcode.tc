int main() {
    int i = 0;
    int sum = 0;
    
    // 循环 100 万次
    while (i < 1000000) {
        // ==========================
        // 这是一堆会被常量折叠的代码
        // ==========================
        int a = 10 + 20 * 30 / 40;
        int b = a + 5;
        
        // ==========================
        // 这是一堆代数化简和死代码
        // ==========================
        int c = b * 0; 
        int d = c + 1; 
        
        // ==========================
        // 冗长的常数运算，其实结果是 0
        // ==========================
        sum = sum + (100 * 200 / 50 + 400 - 300) * 0;
        
        i = i + 1;
    }
    return sum; // 结果一直是 0
}
