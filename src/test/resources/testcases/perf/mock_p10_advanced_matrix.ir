FuncDef: main()
entry_0:
    t0 = ASSIGN 0
    t1 = ASSIGN 1
    t2 = ASSIGN 2
    t3 = ASSIGN 3
    t4 = ASSIGN 4
while_cond_1:
    t5 = SLT t0, 10000000
    BEQZ t5 -> while_end_3
while_body_2:
    t7 = MUL t1, t1
    t8 = MUL t2, t3
    t9 = ADD t7, t8
    t10 = MOD t9, 1000
    t6 = ASSIGN t10
    t12 = MUL t1, t2
    t13 = MUL t2, t4
    t14 = ADD t12, t13
    t15 = MOD t14, 1000
    t11 = ASSIGN t15
    t17 = MUL t3, t1
    t18 = MUL t4, t3
    t19 = ADD t17, t18
    t20 = MOD t19, 1000
    t16 = ASSIGN t20
    t22 = MUL t3, t2
    t23 = MUL t4, t4
    t24 = ADD t22, t23
    t25 = MOD t24, 1000
    t21 = ASSIGN t25
    t1 = ASSIGN t6
    t2 = ASSIGN t11
    t3 = ASSIGN t16
    t4 = ASSIGN t21
    t26 = ADD t0, 1
    t0 = ASSIGN t26
    JMP -> while_cond_1
while_end_3:
    RET t1

