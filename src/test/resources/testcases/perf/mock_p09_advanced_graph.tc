int main() {
    int v0 = 0; int v1 = 1; int v2 = 2; int v3 = 3;
    int v4 = 4; int v5 = 5; int v6 = 6; int v7 = 7;
    int v8 = 8; int v9 = 9; int v10 = 10; int v11 = 11;
    int i = 0;
    while (i < 3000000) {
        v0 = (v0 + v1) % 100;
        v1 = (v1 + v2) % 100;
        v2 = (v2 + v3) % 100;
        v3 = (v3 + v4) % 100;
        v4 = (v4 + v5) % 100;
        v5 = (v5 + v6) % 100;
        v6 = (v6 + v7) % 100;
        v7 = (v7 + v8) % 100;
        v8 = (v8 + v9) % 100;
        v9 = (v9 + v10) % 100;
        v10 = (v10 + v11) % 100;
        v11 = (v11 + v0) % 100;
        i = i + 1;
    }
    return v0 + v11;
}
