FuncDef: main()
entry_0:
    t0 = ASSIGN 1
    t1 = ASSIGN 0
    t2 = ASSIGN 1
    t3 = ASSIGN 0
    t4 = ASSIGN 0
    t5 = SGT t0, 0
    BEQZ t5 -> and_end_2
and_right_1:
    t6 = ASSIGN 1
    t7 = SLT t1, 0
    BNEZ t7 -> or_end_4
or_right_3:
    t8 = SEQ t2, 1
    BNEZ t8 -> or_end_4
    t6 = ASSIGN 0
    JMP -> or_end_4
or_end_4:
    BEQZ t6 -> and_end_2
    t4 = ASSIGN 1
    JMP -> and_end_2
and_end_2:
    BEQZ t4 -> if_end_6
if_then_5:
    t3 = ASSIGN 1
    JMP -> if_end_6
if_end_6:
    t9 = ASSIGN 0
    t10 = ASSIGN 1
    t11 = SEQ t0, 0
    BNEZ t11 -> or_end_10
or_right_9:
    t12 = SEQ t1, 0
    BNEZ t12 -> or_end_10
    t10 = ASSIGN 0
    JMP -> or_end_10
or_end_10:
    BEQZ t10 -> and_end_8
and_right_7:
    t13 = SEQ t2, 1
    BEQZ t13 -> and_end_8
    t9 = ASSIGN 1
    JMP -> and_end_8
and_end_8:
    BEQZ t9 -> if_end_12
if_then_11:
    t14 = ADD t3, 1
    t3 = ASSIGN t14
    JMP -> if_end_12
if_end_12:
    RET t3

