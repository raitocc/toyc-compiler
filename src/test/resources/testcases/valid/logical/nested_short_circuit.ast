      VarDecl (name: c)
        NumberExpr (value: 1)
      VarDecl (name: val)
        NumberExpr (value: 0)
      IfStmt
        cond:
        BinaryExpr (op: &&)
          BinaryExpr (op: >)
            IdExpr (name: a)
            NumberExpr (value: 0)
          BinaryExpr (op: ||)
            BinaryExpr (op: <)
              IdExpr (name: b)
              NumberExpr (value: 0)
            BinaryExpr (op: ==)
              IdExpr (name: c)
              NumberExpr (value: 1)
