FuncDef: sum8(t0, t1, t2, t3, t4, t5, t6, t7)
entry_0:
    t8 = ADD t0, t1
    t9 = ADD t8, t2
    t10 = ADD t9, t3
    t11 = ADD t10, t4
    t12 = ADD t11, t5
    t13 = ADD t12, t6
    t14 = ADD t13, t7
    RET t14

FuncDef: main()
entry_1:
    PARAM 1
    PARAM 2
    PARAM 3
    PARAM 4
    PARAM 5
    PARAM 6
    PARAM 7
    PARAM 8
    t15 = CALL @sum8
    RET t15

