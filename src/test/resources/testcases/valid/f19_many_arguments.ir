FuncDef: add_12(t0, t1, t2, t3, t4, t5, t6, t7, t8, t9, t10, t11)
entry_0:
    t12 = ADD t0, t1
    t13 = ADD t12, t2
    t14 = ADD t13, t3
    t15 = ADD t14, t4
    t16 = ADD t15, t5
    t17 = ADD t16, t6
    t18 = ADD t17, t7
    t19 = ADD t18, t8
    t20 = ADD t19, t9
    t21 = ADD t20, t10
